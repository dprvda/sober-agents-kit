# =====================================================================
# .op-claude.env.example  →  copy to .op-claude.env (gitignored) and edit
# =====================================================================
# Keeps secrets OFF disk. Launch Claude Code with 1Password injecting the
# values into process memory only:
#
#     op run --env-file=.op-claude.env -- claude
#
# Each line maps an env var to a 1Password secret reference (op://VAULT/ITEM/FIELD).
# `op run` resolves them at launch; nothing secret is ever written to disk.
# No 1Password? Instead create a plain gitignored `.env` with KEY=value lines
# and load it however your tools expect (the judge also reads os.environ directly).
# =====================================================================

# ── AI code-review judge (optional module) ──────────────────────────────
# Provider is OpenAI-compatible; defaults target DeepSeek. Override BASE_URL/MODEL
# for any other provider. If LLM_JUDGE_API_KEY is unset, the judge fails OPEN
# (commits still go through) — so this is safe to leave blank until you want it.
LLM_JUDGE_API_KEY=op://YOUR_VAULT/llm-judge-api-key/credential
# LLM_JUDGE_BASE_URL=https://api.deepseek.com      # optional override
# LLM_JUDGE_MODEL=deepseek-chat                    # optional override

# ── GitHub MCP / gh (optional MCP module) ───────────────────────────────
GITHUB_PAT=op://YOUR_VAULT/github-pat/credential

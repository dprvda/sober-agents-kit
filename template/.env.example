# Copy to .env (gitignored) and fill in. The AI-judge gate reads these from the
# environment, falling back to this .env file. A shared low-balance key can be
# handed to a trusted collaborator directly here — no 1Password required.
#
# If LLM_JUDGE_API_KEY is blank, the AI judge simply soft-passes (commits still
# go through) — so the kit is fully functional without it.

# AI code-review judge (OpenAI-compatible; defaults target DeepSeek).
LLM_JUDGE_API_KEY=
# Recommended FREE judge: the NVIDIA build endpoint (one nvapi- key reaches ~121 models, ~40 RPM free).
# Get a key at https://build.nvidia.com -> any model card -> Get API Key.
# LLM_JUDGE_API_KEY=nvapi-...
# LLM_JUDGE_BASE_URL=https://integrate.api.nvidia.com
# LLM_JUDGE_MODEL=mistralai/mistral-medium-3.5-128b
# Any OpenAI-compatible host works (the gate calls {BASE_URL}/v1/chat/completions):
# LLM_JUDGE_BASE_URL=https://api.deepseek.com     # legacy default host
# LLM_JUDGE_MODEL=deepseek-chat

# GitHub MCP / gh (optional MCP module).
# GITHUB_PAT=
